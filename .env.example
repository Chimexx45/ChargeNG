# =============================================================================
# VoltPassNG — Root environment variables (copy to .env and fill in values)
# =============================================================================

# --- General ---
APP_NAME=VoltPassNG
APP_ENV=development
DEBUG=true

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (PostgreSQL) ---
POSTGRES_USER=voltpass
POSTGRES_PASSWORD=change-me
POSTGRES_DB=voltpassng
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis (sessions / caching) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Paystack (Nigeria payments) ---
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- JWT / Auth ---
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- React Dashboard ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Flutter Mobile ---
# Set in mobile/.env or via --dart-define at build time
API_BASE_URL=http://10.0.2.2:8000/api/v1
